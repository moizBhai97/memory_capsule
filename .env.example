# Copy to .env and fill in what you use
# .env is gitignored — never commit real credentials

# AI Provider (ollama is default, no key needed)
# MC_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# API security (leave empty for local use)
# MC_API_KEY=your-secret-key

# Telegram
# MC_TELEGRAM_API_ID=12345678
# MC_TELEGRAM_API_HASH=abcdef...
# MC_TELEGRAM_PHONE=+1234567890

# Email
# MC_EMAIL_HOST=imap.gmail.com
# MC_EMAIL_USERNAME=you@gmail.com
# MC_EMAIL_PASSWORD=your-app-password

# WhatsApp Business
# MC_WA_BUSINESS_TOKEN=EAAx...
# MC_WA_PHONE_ID=123...
# MC_WA_VERIFY_TOKEN=your-verify-token
