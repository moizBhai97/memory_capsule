# Copy to .env and fill in what you use
# .env is gitignored — never commit real credentials

# AI provider API keys — each key covers both LLM and transcription for that provider
# OPENAI_API_KEY=sk-...          # openai/* and groq/* providers (groq uses openai SDK)
# ANTHROPIC_API_KEY=sk-ant-...   # anthropic/*
# GROQ_API_KEY=gsk_...           # groq/*
# GEMINI_API_KEY=AIza...         # gemini/*

# API security (leave empty for local use)
# MC_API_KEY=your-secret-key

# Telegram
# MC_TELEGRAM_API_HASH=abcdef...
# MC_TELEGRAM_API_ID=12345678
# MC_TELEGRAM_PHONE=+1234567890

# Email
# MC_EMAIL_HOST=imap.your-email.com
# MC_EMAIL_PORT=993
# MC_EMAIL_USERNAME=your-email-address
# MC_EMAIL_PASSWORD=your-app-password

# Slack
# MC_SLACK_BOT_TOKEN=xoxb-...
# MC_SLACK_APP_TOKEN=xapp-...   # Socket Mode — enable in app settings

# Discord
# MC_DISCORD_BOT_TOKEN=your-bot-token

# WhatsApp Business
# MC_WA_BUSINESS_TOKEN=EAAx...
# MC_WA_BUSINESS_PHONE_ID=123...
# MC_WA_BUSINESS_VERIFY_TOKEN=your-verify-token
